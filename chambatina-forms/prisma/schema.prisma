generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Submission {
  id            String   @id @default(cuid())
  trackingNumber String  @unique
  name          String
  identity      String
  phone         String
  province      String
  address       String
  weight        Float
  packages      Int
  description   String
  embarcador    String   @default("CHAMBATINA MIAMI")
  status        String   @default("PENDIENTE")
  syncedToSolvedcargo Boolean @default(false)
  solvedcargoId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
