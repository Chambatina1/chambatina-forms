generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Shipment {
  id            String   @id @default(cuid())
  // Datos del remitente (embarcador - quien envia desde Miami)
  sname         String   @default("") // Nombre del remitente
  sphone        String   @default("") // Telefono del remitente
  saddress      String   @default("") // Direccion del remitente
  semail        String   @default("") // Email del remitente
  // Datos del destinatario (consignatario - quien recibe en Cuba)
  cname         String   // Nombre completo del destinatario
  cidentity     String   // Carnet de identidad
  cphone        String   // Telefono
  caddress      String   @default("") // Direccion
  cprovince     String   @default("") // Provincia
  // Datos del envio
  weight        String   @default("") // Peso en lb
  npieces       String   @default("1") // Cantidad de bultos
  description   String   @default("") // Descripcion de mercancia
  cnotes        String   @default("") // Notas adicionales
  // IDs de SolvedCargo
  shipperIdApi  String   @default("") // ID del shipper creado en API
  consigneeIdApi String  @default("") // ID del consignee creado en API
  // Estado y seguimiento
  cpkNumber     String   @default("") // Numero CPK asignado manualmente
  status        String   @default("PENDIENTE") // PENDIENTE, REGISTRADO, EN_TRANSITO, ENTREGADO
  syncedToApi   Boolean  @default(false) // Si se registro en SolvedCargo API
  apiResponse   String   @default("") // Respuesta raw de la API
  // Metadatos
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
