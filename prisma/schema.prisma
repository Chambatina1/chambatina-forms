generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Shipment {
  id            String   @id @default(cuid())
  // Datos del destinatario
  cname         String   // Nombre completo del destinatario
  cidentity     String   // Carnet de identidad
  cphone        String   // Telefono
  caddress      String   @default("") // Direccion
  cprovince     String   @default("") // Provincia
  // Datos del envio
  weight        String   @default("") // Peso en lb
  npieces       String   @default("1") // Cantidad de bultos
  description   String   @default("") // Descripcion de mercancia
  cnotes        String   @default("") // Notas adicionales
  // Estado y seguimiento
  cpkNumber     String   @default("") // Numero CPK asignado manualmente
  status        String   @default("PENDIENTE") // PENDIENTE, REGISTRADO, EN_TRANSITO, ENTREGADO
  syncedToApi   Boolean  @default(false) // Si se registro en SolvedCargo API
  // Metadatos
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
